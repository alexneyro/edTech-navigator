rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "alexneyro99@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'name']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['student', 'admin'] &&
             data.name is string;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'status', 'subtasks', 'createdAt']) &&
             data.id is string &&
             data.userId is string &&
             data.title is string &&
             data.title.size() < 200 &&
             data.status in ['todo', 'in-progress', 'done'] &&
             data.subtasks is list &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin()) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidTask(request.resource.data) && (resource.data.userId == request.auth.uid || isAdmin()) &&
                    request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /ai_profiles/{profileId} {
      allow read: if isAdmin(); // Students shouldn't see API keys
      allow write: if isAdmin();
    }

    match /settings/ai {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
